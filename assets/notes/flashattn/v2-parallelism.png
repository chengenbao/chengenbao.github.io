<svg width="720" height="360" xmlns="http://www.w3.org/2000/svg" font-family="'Segoe UI',Arial,sans-serif">
  <rect width="720" height="360" fill="#fff"/>
  <text x="360" y="28" text-anchor="middle" font-size="15" font-weight="bold" fill="#1a1a2e">FlashAttention v2：循环顺序优化与序列维度并行</text>

  <!-- v1 循环 -->
  <text x="175" y="58" text-anchor="middle" font-size="13" font-weight="bold" fill="#c0392b">v1 循环顺序</text>
  <rect x="30" y="68" width="290" height="50" rx="6" fill="#fef9e7" stroke="#f39c12" stroke-width="1.5"/>
  <text x="175" y="89" text-anchor="middle" font-size="12" fill="#7f6000">外层：遍历 K/V 块 j=1..T_c</text>
  <text x="175" y="108" text-anchor="middle" font-size="12" fill="#7f6000">内层：遍历 Q 块 i=1..T_r</text>
  <text x="175" y="136" text-anchor="middle" font-size="11" fill="#c0392b">→ Q 块需在外层 K/V 循环结束后才能输出</text>
  <text x="175" y="154" text-anchor="middle" font-size="11" fill="#c0392b">→ 并行维度：batch × head（序列不可并行）</text>

  <!-- GPU 利用图 v1 -->
  <text x="175" y="180" text-anchor="middle" font-size="11" fill="#888">SM 利用（序列=4K，32个SM）：</text>
  <rect x="50" y="188" width="250" height="22" rx="4" fill="#eee" stroke="#ccc"/>
  <rect x="50" y="188" width="88" height="22" rx="4" fill="#e74c3c"/>
  <text x="175" y="203" text-anchor="middle" font-size="11" fill="#333">~35% 利用率（SM 大量空闲）</text>

  <!-- v2 循环 -->
  <text x="545" y="58" text-anchor="middle" font-size="13" font-weight="bold" fill="#1565c0">v2 循环顺序</text>
  <rect x="400" y="68" width="290" height="50" rx="6" fill="#e8f4fd" stroke="#1565c0" stroke-width="1.5"/>
  <text x="545" y="89" text-anchor="middle" font-size="12" fill="#0d47a1">外层：遍历 Q 块 i=1..T_r</text>
  <text x="545" y="108" text-anchor="middle" font-size="12" fill="#0d47a1">内层：遍历 K/V 块 j=1..T_c</text>
  <text x="545" y="136" text-anchor="middle" font-size="11" fill="#1565c0">→ 每个 Q 块独立，可分配独立 thread block</text>
  <text x="545" y="154" text-anchor="middle" font-size="11" fill="#1565c0">→ 并行维度：batch × head × Q序列</text>

  <!-- GPU 利用图 v2 -->
  <text x="545" y="180" text-anchor="middle" font-size="11" fill="#888">SM 利用（序列=4K，32个SM）：</text>
  <rect x="420" y="188" width="250" height="22" rx="4" fill="#eee" stroke="#ccc"/>
  <rect x="420" y="188" width="183" height="22" rx="4" fill="#27ae60"/>
  <text x="545" y="203" text-anchor="middle" font-size="11" fill="#333">~73% 利用率</text>

  <!-- 分隔线 -->
  <line x1="355" y1="50" x2="355" y2="220" stroke="#ddd" stroke-width="1"/>

  <!-- Warp 分工对比 -->
  <text x="360" y="240" text-anchor="middle" font-size="13" font-weight="bold" fill="#1a1a2e">Warp 分工优化</text>
  <rect x="30" y="252" width="290" height="52" rx="6" fill="#ffeaea" stroke="#c0392b" stroke-width="1.5"/>
  <text x="175" y="272" text-anchor="middle" font-size="12" font-weight="bold" fill="#c0392b">v1：Split-K 策略</text>
  <text x="175" y="290" text-anchor="middle" font-size="11" fill="#555">多个 warp 各算部分 K/V</text>
  <text x="175" y="306" text-anchor="middle" font-size="11" fill="#c0392b">→ warp 间需 synchronize + reduce</text>

  <rect x="400" y="252" width="290" height="52" rx="6" fill="#e8f5e9" stroke="#2e7d32" stroke-width="1.5"/>
  <text x="545" y="272" text-anchor="middle" font-size="12" font-weight="bold" fill="#2e7d32">v2：每 Warp 独立</text>
  <text x="545" y="290" text-anchor="middle" font-size="11" fill="#555">每个 warp 处理完整 Q-K/V tile</text>
  <text x="545" y="306" text-anchor="middle" font-size="11" fill="#2e7d32">→ 消除 warp 间通信开销</text>

  <text x="360" y="345" text-anchor="middle" font-size="11" fill="#7f8c8d">A100 峰值利用率：v1 ~35% → v2 ~73%（速度约 2x）</text>
</svg>